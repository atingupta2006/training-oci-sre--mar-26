# Chaos — CHAOS_ERROR_RATE 0–1 (Day-2 uses 0.1). Use 0 for no injected 500s.
chaos_enabled            = true
chaos_latency_ms         = 80
chaos_error_rate         = 0.1

# OpenTelemetry: NDJSON spans to OTEL_TRACES_LOG_FILE (see env.tpl). false = no OTEL_* in .env
otel_tracing_enabled  = false
otel_service_name     = "bharatmart-backend"
otel_traces_log_file  = ""

# true = insert each API request into Supabase api_events; false = skip (e.g. table not created yet)
enable_api_events_db = true


############################################################
# IMAGE SETTINGS
############################################################

# Auto-discover OL9 image for correct region + shape
os_version = "9"

use_custom_images        = false
frontend_custom_image_id = null
backend_custom_image_id  = null


############################################################
# FRONTEND SETTINGS
############################################################

frontend_instance_count = 1
frontend_shape          = "VM.Standard.E5.Flex"

# Flex shape configuration
frontend_flex_ocpus      = 2
frontend_flex_memory_gbs = 12

frontend_port = 80


############################################################
# BACKEND INSTANCE POOL SETTINGS
############################################################

backend_shape           = "VM.Standard.E5.Flex"
backend_flex_ocpus      = 2
backend_flex_memory_gbs = 12

backend_api_port = 3000

backend_lb_health_check_path = "/"

backend_pool_initial_size = 2
backend_pool_min_size     = 1
backend_pool_max_size     = 10


############################################################
# AUTOSCALING RULES
############################################################

backend_cpu_scale_out_threshold = 70
backend_cpu_scale_in_threshold  = 30


############################################################
# LOAD BALANCER SETTINGS
############################################################

lb_min_bandwidth_mbps = 10
lb_max_bandwidth_mbps = 100


############################################################
# PROJECT METADATA
############################################################

project_name = "bharatmart"
