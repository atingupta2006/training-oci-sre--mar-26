# ═══════════════════════════════════════════════════════════
# BharatMart Configuration
# ═══════════════════════════════════════════════════════════
# 🎯 QUICK START: Copy this file to .env and configure
# 📚 Documentation: See CONFIGURATION_GUIDE.md for details
# 📦 Sample Configs: See config/samples/ for ready-to-use configs
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# 🚀 QUICK SETUP (Choose One)
# ───────────────────────────────────────────────────────────
# Instead of manually configuring below, copy a sample config:
#
# Local Dev:      cp config/samples/local-dev-minimal.env .env
# Production VM:  cp config/samples/single-vm-production.env .env
# Multi-VM:       cp config/samples/multi-vm-supabase.env .env
# Kubernetes:     cp config/samples/kubernetes-production.env .env
# OCI Full:       cp config/samples/oci-full-stack.env .env
#
# See config/samples/README.md for all options

# ───────────────────────────────────────────────────────────
# DEPLOYMENT MODE
# ───────────────────────────────────────────────────────────
# Options: single-vm | multi-tier | kubernetes
DEPLOYMENT_MODE=single-vm

# ───────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────
# Options: sqlite | postgresql | supabase | mysql | oci-autonomous
DATABASE_TYPE=supabase

# ┌─────────────────────────────────────────────────────────┐
# │ OPTION 1: SQLite (Minimal - Zero Setup)                │
# └─────────────────────────────────────────────────────────┘
# DATABASE_TYPE=sqlite
# DATABASE_PATH=./bharatmart.db

# ┌─────────────────────────────────────────────────────────┐
# │ OPTION 2: Supabase (Recommended - Easy + Free Tier)    │
# └─────────────────────────────────────────────────────────┘
SUPABASE_URL=https://zdqkotajomqmcfrnxmac.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpkcWtvdGFqb21xbWNmcm54bWFjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQzMDc0MTAsImV4cCI6MjA4OTg4MzQxMH0.yloNemspJzogcf20w7nw4CyUlRb8RknH5jqO6Kcy-5k
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpkcWtvdGFqb21xbWNmcm54bWFjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDMwNzQxMCwiZXhwIjoyMDg5ODgzNDEwfQ.xlThdGsWexYFH3nGIUiU6Yd7stt2v3321GITXcAABzA

# ┌─────────────────────────────────────────────────────────┐
# │ OPTION 3: PostgreSQL (Self-Hosted)                     │
# └─────────────────────────────────────────────────────────┘
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:pass@localhost:5432/bharatmart
# DATABASE_POOL_MIN=5
# DATABASE_POOL_MAX=20

# ┌─────────────────────────────────────────────────────────┐
# │ OPTION 4: OCI Autonomous Database                      │
# └─────────────────────────────────────────────────────────┘
# DATABASE_TYPE=oci-autonomous
# OCI_DB_CONNECTION_STRING=tcps://adb.ap-mumbai-1.oraclecloud.com:1522/xxx
# OCI_DB_USER=admin
# OCI_DB_PASSWORD=YourPassword123!
# OCI_DB_WALLET_PATH=/opt/oracle/wallet

# ───────────────────────────────────────────────────────────
# AUTHENTICATION
# ───────────────────────────────────────────────────────────
# Options: local | supabase
AUTH_PROVIDER=supabase

# For local JWT auth (when DATABASE_TYPE=sqlite or postgresql):
# AUTH_PROVIDER=local
# JWT_SECRET=your-secret-key-minimum-32-characters-long
# JWT_EXPIRY=1h
# JWT_REFRESH_EXPIRY=7d

# ───────────────────────────────────────────────────────────
# BACKGROUND WORKERS
# ───────────────────────────────────────────────────────────
# Options: in-process | bull-queue | oci-queue | sqs | none
WORKER_MODE=in-process

# For Bull Queue + Redis (production):
# WORKER_MODE=bull-queue
# QUEUE_REDIS_URL=redis://localhost:6379
# WORKER_CONCURRENCY=5

# ───────────────────────────────────────────────────────────
# CACHE CONFIGURATION
# ───────────────────────────────────────────────────────────
# Options: memory | redis | oci-cache
CACHE_TYPE=memory

# For Redis cache:
# CACHE_TYPE=redis
# CACHE_REDIS_URL=redis://localhost:6379
# CACHE_TTL=600

# ───────────────────────────────────────────────────────────
# SECRETS MANAGEMENT
# ───────────────────────────────────────────────────────────
# Options: env | oci-vault | aws-secrets | azure-keyvault
SECRETS_PROVIDER=env

# ───────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION
# ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=BharatMart

# If using Supabase:
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpkcWtvdGFqb21xbWNmcm54bWFjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQzMDc0MTAsImV4cCI6MjA4OTg4MzQxMH0.yloNemspJzogcf20w7nw4CyUlRb8RknH5jqO6Kcy-5k

# ───────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=dev
ENABLE_METRICS=true

# ───────────────────────────────────────────────────────────
# 📦 SAMPLE CONFIGURATIONS
# ───────────────────────────────────────────────────────────
# Complete sample configs available in config/samples/:
#
# Development:
#   - local-dev-minimal.env       (SQLite, zero setup)
#   - local-dev-full.env          (PostgreSQL + Redis local)
#
# Single VM:
#   - single-vm-basic.env         (Supabase, simple)
#   - single-vm-production.env    (With Redis workers)
#   - single-vm-local-stack.env   (All local services)
#
# Multi-VM:
#   - multi-vm-supabase.env       (Auto-scaling with Supabase)
#   - multi-vm-postgresql.env     (With dedicated DB server)
#
# Cloud:
#   - oci-full-stack.env          (All OCI services)
#   - kubernetes-production.env    (K8s with HPA)
#   - hybrid-supabase-oci.env     (Best value combo)
#
# Database Variations:
#   - db-sqlite.env               (Lightweight)
#   - db-postgresql.env           (Production)
#
# Worker Variations:
#   - workers-bull-redis.env      (Reliable queues)
#
# Cache Variations:
#   - cache-redis-cluster.env     (High availability)
#
# See config/samples/README.md for detailed comparison

